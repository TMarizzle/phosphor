            "id": "script-structure",
            "type": "screen",
            "content": [
                {
                    "type": "text",
                    "className": "alert",
                    "text": "SECTION: SCRIPT STRUCTURE"
                },
                "",
                "Top-level shape:",
                "{",
                "  \"config\": { \"name\": \"My Script\", \"author\": \"You\" },",
                "  \"screens\": [ ... ],",
                "  \"dialogs\": [ ... ]",
                "}",
                "",
                "Screen shape:",
                "{",
                "  \"id\": \"unique-id\",",
                "  \"type\": \"screen\" | \"static\",",
                "  \"content\": [ ... ],",
                "  \"onDone\": { \"target\": \"next-id\", \"delayMs\": 1200 }",
                "}",
                "",
                "screen = progressive render, static = immediate render",
                {
                    "type": "link",
                    "text": "> VIEW STATIC SCREEN EXAMPLE",
                    "target": "static-reference"
                },
                {
                    "type": "link",
                    "text": "> NEXT: ELEMENT TYPES",
                    "target": "element-types"
                },
                {
                    "type": "link",
                    "text": "> PREVIOUS: CREATOR WORKFLOW",
                    "target": "creator-workflow"
                },
                {
                    "type": "link",
                    "text": "> TABLE OF CONTENTS",
                    "target": "hub"
                }
            ]
        },

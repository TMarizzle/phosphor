        {
            "id": "element-types",
            "type": "screen",
            "content": [
                {
                    "type": "text",
                    "className": "alert",
                    "text": "SECTION: ELEMENT TYPES"
                },
                "",
                "Element map (creator label -> JSON shape):",
                "- Text Line -> \"plain string\"",
                "- Text Block / Alert / Notice / Emphasis / System -> { \"type\": \"text\", \"text\": \"...\" }",
                "- Link Button -> { \"type\": \"link\", \"text\": \"...\", \"target\": \"screenId\" | [targets] }",
                "- Bitmap/Image -> { \"type\": \"bitmap\" | \"image\", \"src\": \"...\" }",
                "- Prompt Input -> { \"type\": \"prompt\", \"prompt\": \"...\", \"caseSensitive\": true|false, \"cursor\": true|false, \"commands\": [...] }",
                "- Login Prompt -> { \"type\": \"login\", \"usernameCaseSensitive\": true|false, \"hideUsername\": true|false, \"passwordCaseSensitive\": true|false, \"hidePassword\": true|false, \"credentials\": [...], \"noMatchAction\": {...} }",
                "- Toggle -> { \"type\": \"toggle\", \"states\": [...] }",
                "- List -> { \"type\": \"list\", \"states\": [...] }",
                "- Report Composer -> { \"type\": \"reportComposer\", \"titleTemplate\": \"...\", \"template\": \"...\" }",
                "- Report List -> { \"type\": \"reportList\", \"composerId\": \"...\" }",
                "- Dialog Link (+ Dialog) -> link target entry { \"type\": \"dialog\", \"target\": \"dialogId\" } + dialogs[] row",
                "",
                {
                    "type": "link",
                    "text": "> LIVE ELEMENT EXAMPLES",
                    "target": "live-elements"
                },
                {
                    "type": "link",
                    "text": "> NEXT: PROMPT BEHAVIOR",
                    "target": "prompt-behavior"
                },
                {
                    "type": "link",
                    "text": "> PREVIOUS: SCRIPT STRUCTURE",
                    "target": "script-structure"
                },
                {
                    "type": "link",
                    "text": "> TABLE OF CONTENTS",
                    "target": "hub"
                }
            ]
        },
